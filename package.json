{
  "name": "countdown-wallpaper",
  "version": "1.0.0",
  "description": "简约清新风格的桌面动态倒计时壁纸工具",
  "main": "dist-electron/main.js",
  "author": "Countdown Wallpaper",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "build:renderer": "vue-tsc --noEmit && vite build",
    "build:electron": "electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "naive-ui": "^2.38.1",
    "dayjs": "^1.11.10",
    "@vicons/antd": "^0.12.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "typescript": "^5.4.3",
    "vite": "^5.2.6",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5",
    "electron": "^29.1.5",
    "electron-builder": "^24.13.3",
    "vue-tsc": "^2.0.7",
    "@types/node": "^20.11.30",
    "sass": "^1.72.0"
  },
  "build": {
    "appId": "com.countdown.wallpaper",
    "productName": "Countdown Wallpaper",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
